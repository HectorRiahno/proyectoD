# =====================================================================
# .gitignore — Proyecto HIS
# Solo se trackea lo necesario para correr el proyecto en local y
# desplegarlo en Vercel/Netlify. Builds, secretos, cachés y configs de
# herramientas locales quedan fuera.
# =====================================================================

# ─── Logs ────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Secretos y variables de entorno ─────────────────────────────────
# Nunca subir .env — usar .env.example como plantilla para nuevos devs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.pem
*.key

# ─── Dependencias y artefactos de build ──────────────────────────────
node_modules
dist
dist-ssr
build
out
*.local

# ─── Cachés de bundler / framework ───────────────────────────────────
.vite/
.parcel-cache/
.next/
.cache/
.turbo/
.eslintcache

# ─── Plataformas de despliegue ───────────────────────────────────────
.vercel/
.netlify/

# ─── Tests / coverage ────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── TypeScript ──────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Supabase CLI local (cachés y branches no se versionan) ──────────
supabase/.temp/
supabase/.branches/

# ─── Migraciones SQL históricas (versiones reemplazadas) ─────────────
# Las migraciones VIGENTES quedan tracked. Estas son las viejas que ya
# fueron sustituidas por migrations posteriores y mantenerlas confunde.
.supabase/auth-trigger.sql
supabase/migration-consulta.sql
supabase/migration-factura-fk.sql
supabase/realtime.sql
supabase/rls-admin.sql
supabase/rls-medico.sql
supabase/schema.sql
supabase/seed.sql
supabase/views.sql

# ─── Config de herramientas de IA / asistentes locales ───────────────
.claude/
.cursor/
.aider*
.codeium/

# ─── Notas y borradores internos ─────────────────────────────────────
context.md
NOTES.md
TODO.md
*.draft.md

# ─── IDE / editor ────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Archivos de SO ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/
